{
  "mcpServers": {
    "@magicuidesign/mcp": {
      "args": [
        "-y",
        "@magicuidesign/mcp@latest"
      ],
      "command": "npx",
      "disabled": false
    },
    "browsermcp": {
      "args": [
        "@browsermcp/mcp@latest"
      ],
      "command": "npx",
      "disabled": true
    },
    "mcp-playwright": {
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "command": "npx",
      "disabled": false,
      "env": {}
    },
    "sequential-thinking": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "npx",
      "disabled": true,
      "env": {}
    },
    "fetch": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "command": "npx",
      "disabled": false,
      "env": {},
      "autoApprove": []
    }
  }
}