{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IRIS Widget",
  "version": "0.1.0",
  "identifier": "com.iris.widget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "IRIS Widget",
        "width": 680,
        "height": 680,
        "minWidth": 680,
        "minHeight": 680,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "visible": true,
        "shadow": false,
        "dragDropEnabled": false,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "mobile": [{
        "host": "oauth",
        "pathPrefix": ["/callback"]
      }],
      "desktop": {
        "schemes": ["iris"]
      }
    }
  }
}